rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /breakdown_requests/{requestId} {
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;

      allow read: if isSignedIn()
        && resource.data.userId == request.auth.uid;

      allow update: if isSignedIn()
        && resource.data.userId == request.auth.uid;

      match /bids/{bidId} {
        allow read: if isSignedIn()
          && get(/databases/$(database)/documents/breakdown_requests/$(requestId)).data.userId == request.auth.uid;

        // Demo: client writes simulated shop bids. Restrict to Cloud Functions in production.
        allow create: if isSignedIn();
      }
    }

    match /shops/{shopId} {
      allow read: if isSignedIn();
    }
  }
}
