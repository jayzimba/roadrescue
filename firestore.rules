rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /shops/{shopId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid;
      allow update: if isSignedIn()
        && resource.data.ownerId == request.auth.uid;

      match /private/{docId} {
        allow read, write: if isSignedIn()
          && get(/databases/$(database)/documents/shops/$(shopId)).data.ownerId == request.auth.uid;
      }
    }

    match /part_listings/{listingId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isSignedIn()
        && resource.data.ownerId == request.auth.uid;
    }

    match /service_listings/{listingId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isSignedIn()
        && resource.data.ownerId == request.auth.uid;
    }

    match /orders/{orderId} {
      allow create: if isSignedIn()
        && request.resource.data.buyerId == request.auth.uid;
      allow read: if isSignedIn()
        && (resource.data.buyerId == request.auth.uid
          || resource.data.shopOwnerId == request.auth.uid);
      allow update: if isSignedIn()
        && resource.data.shopOwnerId == request.auth.uid;
    }

    match /service_bookings/{bookingId} {
      allow create: if isSignedIn()
        && request.resource.data.buyerId == request.auth.uid;
      allow read: if isSignedIn()
        && (resource.data.buyerId == request.auth.uid
          || resource.data.shopOwnerId == request.auth.uid);
      allow update: if isSignedIn()
        && resource.data.shopOwnerId == request.auth.uid;
    }

    match /breakdown_requests/{requestId} {
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;

      allow read: if isSignedIn()
        && (resource.data.userId == request.auth.uid
          || resource.data.status == 'BIDDING'
          || resource.data.acceptedShopId == getShopIdForUser());

      allow update: if isSignedIn()
        && resource.data.userId == request.auth.uid;

      match /bids/{bidId} {
        allow read: if isSignedIn()
          && (get(/databases/$(database)/documents/breakdown_requests/$(requestId)).data.userId == request.auth.uid
            || get(/databases/$(database)/documents/breakdown_requests/$(requestId)).data.status == 'BIDDING');

        allow create: if isSignedIn()
          && get(/databases/$(database)/documents/breakdown_requests/$(requestId)).data.status == 'BIDDING';
      }
    }

    function getShopIdForUser() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.shopId;
    }
  }
}
